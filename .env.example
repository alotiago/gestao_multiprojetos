# Copie este arquivo para .env e preencha os valores para seu ambiente local.
# Nunca commite o arquivo .env com valores reais.

# ----------------------------------------
# Aplicação
# ----------------------------------------
APP_ENV=development
APP_PORT=3000
APP_SECRET_KEY=troque-por-uma-chave-secreta-forte

# ----------------------------------------
# Banco de Dados
# ----------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestao_multiprojetos
DB_USER=postgres
DB_PASSWORD=troque-por-uma-senha-forte

# ----------------------------------------
# E-mail (para notificações)
# ----------------------------------------
MAIL_HOST=smtp.exemplo.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@gestao-multiprojetos.local

# ----------------------------------------
# Autenticação JWT
# ----------------------------------------
JWT_SECRET=troque-por-um-segredo-jwt-forte
JWT_EXPIRES_IN=8h
