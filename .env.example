# ===== AMBIENTE =====
NODE_ENV=development
LOG_LEVEL=debug

# ===== BANCO DE DADOS =====
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=gestor_multiprojetos
DATABASE_USER=admin
DATABASE_PASSWORD=ChangeMe123!
DATABASE_URL=postgresql://admin:ChangeMe123!@postgres:5432/gestor_multiprojetos?schema=public

# ===== REDIS (CACHE) =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ChangeMe123!

# ===== BACKEND =====
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# ===== AUTENTICAÇÃO JWT =====
# Chaves para assinar tokens (gerar com: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-key-change-in-production-32-char-min
JWT_EXPIRES_IN=3600
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-32-char-min
JWT_REFRESH_EXPIRES_IN=604800

# ===== FRONTEND =====
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ===== KEYCLOAK (OPCIONAL PARA FUTURO) =====
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=gestor-multiprojetos
KEYCLOAK_CLIENT_ID=gestor-multiprojetos-api
KEYCLOAK_CLIENT_SECRET=your-keycloak-secret

# ===== MONITORAMENTO =====
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002

# ===== INTEGRACOES FUTURAS =====
SENTRY_DSN=
SLACK_WEBHOOK_URL=
EMAIL_PROVIDER=
EMAIL_FROM=
