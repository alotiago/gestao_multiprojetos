# ============================================
# Gestor Multiprojetos — Variáveis de Produção
# ============================================
# ATENÇÃO: Altere TODOS os valores antes do deploy!
# NUNCA commite este arquivo no repositório.
# ============================================

# ---- Banco de Dados ----
DATABASE_NAME=gestor_multiprojetos
DATABASE_USER=gestor_admin
DATABASE_PASSWORD=ALTERE_PARA_SENHA_FORTE_AQUI     # Mínimo 20 caracteres

# ---- Redis ----
REDIS_PASSWORD=ALTERE_PARA_SENHA_FORTE_AQUI

# ---- JWT (gere com: openssl rand -base64 64) ----
JWT_SECRET=ALTERE_GERE_COM_OPENSSL_RAND_BASE64_64
JWT_REFRESH_SECRET=ALTERE_GERE_COM_OPENSSL_RAND_BASE64_64
JWT_EXPIRATION=1h

# ---- URLs ----
FRONTEND_URL=https://gestor.seudominio.com.br
NEXT_PUBLIC_API_URL=https://gestor.seudominio.com.br
BACKEND_PORT=3001

# ---- Grafana ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=ALTERE_PARA_SENHA_FORTE_AQUI
GRAFANA_URL=https://gestor.seudominio.com.br/grafana

# ---- Ambiente ----
NODE_ENV=production
